# Google Gemini API key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Postgres connection string (matches docker-compose.yml defaults).
# On Railway, set this to ${{ Postgres.DATABASE_URL }} instead.
DATABASE_URL=postgres://admin:admin123@localhost:5432/ai-chat-bot

# Secret required to call POST /faq/seed in environments with no shell access
# (e.g. Render/Railway free tiers). Set a long random value in production.
FAQ_SEED_SECRET=change-me

# There are no migrations yet, so a brand-new database has no tables.
# Set this to true for your app's *first* run against a fresh database to
# let TypeORM create the schema from the entities, then set it back to
# false (or unset it) — leaving it on risks unreviewed schema drift.
DB_SYNCHRONIZE=false
